# Database (local: use same as docker-compose postgres service)
DATABASE_URL=postgresql://bugs:bugs@localhost:5432/bugs_reporter

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: OpenAI for AI-generated titles and structured fields
OPENAI_API_KEY=

# App
PORT=3000
LOG_LEVEL=info
