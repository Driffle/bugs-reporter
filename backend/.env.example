# Slack
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
CHANNEL_ID=C01234567
PROCESS_THREADS=false

# Plane (self-hosted: use your instance URL, e.g. https://plan.driffle.org)
PLANE_BASE_URL=https://plan.driffle.org
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=driffle
PLANE_PROJECT_ID=
