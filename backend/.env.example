# For `npm run start:dev` from ./backend, copy to backend/.env
# Canonical variable list for Docker + Deployer: see repo root ../.env.example

# Slack
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
CHANNEL_ID=C01234567
PROCESS_THREADS=false

# Plane
PLANE_BASE_URL=https://plan.driffle.org
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=driffle
PLANE_PROJECT_ID=
PLANE_STATE_ID=
PLANE_LABEL_IDS=

# Database — use localhost when Postgres is on host or published by docker-compose.yml
DATABASE_URL=postgresql://bugs:bugs@localhost:5432/bugs_reporter

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

OPENAI_API_KEY=
PORT=3000
LOG_LEVEL=info
