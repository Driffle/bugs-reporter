# Copy to .env at repo root (never commit .env or .deployer.env).
# Used by docker-compose*.yml (env_file + substitution). Align names with Deployer managed keys when backends are provisioned there.

# --- App (NestJS) ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Inside Compose: use service hostnames. Host-run Nest against compose DBs: use localhost ---
DATABASE_URL=postgresql://bugs:bugs@postgres:5432/bugs_reporter
POSTGRES_USER=bugs
POSTGRES_PASSWORD=bugs
POSTGRES_DB=bugs_reporter

# Redis (BullMQ). Deployer may inject REDIS_URL; else host redis + port
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
CHANNEL_ID=C01234567
PROCESS_THREADS=false

# --- Plane (self-hosted) ---
PLANE_BASE_URL=https://plan.driffle.org
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=driffle
PLANE_PROJECT_ID=
PLANE_STATE_ID=
PLANE_LABEL_IDS=

# --- Optional ---
OPENAI_API_KEY=
