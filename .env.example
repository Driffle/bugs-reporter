# Copy to .env at repo root (never commit .env or .deployer.env).
#
# --- Deployer (https://deployer.driffle.net/) ---
# Enable Postgres + Redis in the app, then EITHER:
#   • Leave "App .env" empty and let the platform inject DATABASE_URL / REDIS_* from managed backends, OR
#   • Paste the connection strings from Deployer (Overview / env / .deployer.env) into App .env if injection fails.
# Never use bugs:bugs on Deployer — the platform uses its own DB name and password (e.g. driffle_bugs_reporter).
#
# --- Local docker compose (embedded postgres/redis) ---
# Use the values below so Prisma matches the postgres service in docker-compose.prod.yml.

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://bugs:bugs@postgres:5432/bugs_reporter
POSTGRES_USER=bugs
POSTGRES_PASSWORD=bugs
POSTGRES_DB=bugs_reporter

REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Slack: set these in Deployer → App .env (local .env is not deployed).
SLACK_BOT_TOKEN=xoxb-
# Signing Secret from api.slack.com → Your app → Basic Information (not the bot token).
SLACK_SIGNING_SECRET=
CHANNEL_ID=C01234567
PROCESS_THREADS=false

PLANE_BASE_URL=https://plan.driffle.org
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=driffle
PLANE_PROJECT_ID=
PLANE_STATE_ID=
PLANE_LABEL_IDS=

OPENAI_API_KEY=
